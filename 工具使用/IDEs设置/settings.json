{
    "editor.fontSize": 13,
    "editor.tabSize": 2,
    "files.exclude": {
        "**/.idea": true
    },
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    "workbench.iconTheme": "material-icon-theme",
    "editor.guides.bracketPairs": "active",
    "explorer.copyRelativePathSeparator": "/",
    "explorer.fileNesting.enabled": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "smooth",
    "window.title": "${rootName}${separator}${activeEditorMedium}${separator}${profileName}",
    "editor.stickyScroll.maxLineCount": 10,
    "window.confirmBeforeClose": "keyboardOnly",
    "editor.minimap.showSlider": "always",
    "files.autoSave": "onWindowChange",
    "editor.fontFamily": "Fira Code, Menlo, Monaco, 'Courier New', monospace",
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.verticalScrollbarSize": 0,
    "editor.guides.indentation": false,
    "search.exclude": {
        "**/*.logs": true
    },
    "window.zoomPerWindow": false,
    "files.insertFinalNewline": true,
    "vue.splitEditors.icon": true,
    "vue.inlayHints.missingProps": true,
    "vue.inlayHints.inlineHandlerLeading": true,
    "typescript.inlayHints.variableTypes.enabled": true,
    "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
    "typescript.inlayHints.parameterTypes.enabled": true,
    "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
    "typescript.inlayHints.enumMemberValues.enabled": true,
    "js/ts.implicitProjectConfig.target": "ESNext",
    "eslint.codeActionsOnSave.mode": "problems",
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "[vue]": {
        "editor.defaultFormatter": "Vue.volar"
    },
    "merge-conflict.autoNavigateNextConflict.enabled": true,
    "chat.editor.fontSize": 13,
    "search.collapseResults": "auto",
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "editor.inlineSuggest.suppressSuggestions": true,
    "inlineChat.holdToSpeech": false,
    "diffEditor.renderSideBySide": true,
    "diffEditor.useInlineViewWhenSpaceIsLimited": false,
    "clipboard-manager.maxClips": 40,
    "diffEditor.experimental.showMoves": true,
    "diffEditor.hideUnchangedRegions.enabled": true,
    "workbench.editor.tabActionCloseVisibility": false,
    "workbench.view.alwaysShowHeaderActions": true,
    "git.blame.editorDecoration.enabled": true,
    "vue.complete.casing.tags": "autoKebab",
    "liveServer.settings.donotShowInfoMsg": true,
    "liveServer.settings.donotVerifyTags": true,
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.vue": "default"
    },
    "git.replaceTagsWhenPull": true,
    "[markdown]": {
        "diffEditor.ignoreTrimWhitespace": false
    },
    "debug.console.fontSize": 13,
    "terminal.integrated.fontSize": 13,
    "search.seedOnFocus": true,
    "search.showLineNumbers": true,
    "workbench.colorTheme": "Webstorm New Dark",
    "workbench.tree.stickyScrollMaxItemCount": 10,
    "problems.visibility": false
}
